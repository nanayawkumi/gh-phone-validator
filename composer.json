{
    "name": "nanayawkumi/gh-phone-validator",
    "description": "Laravel validation rule and helpers for Ghana phone numbers",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel Kumi-Buabeng"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Nanayawkumi\\GhPhoneValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nanayawkumi\\GhPhoneValidator\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nanayawkumi\\GhPhoneValidator\\GhPhoneValidatorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}